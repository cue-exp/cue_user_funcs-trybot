env HOME=$WORK/.home
exec cue_user_funcs export .
cmp stdout expected.json

-- example.cue --
@extern(inject)

package example

#Untitle:       _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Untitle")
#Substr:        _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Substr")
#Nospace:       _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Nospace")
#Trunc:         _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Trunc")
#Abbrev:        _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Abbrev")
#Abbrevboth:    _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Abbrevboth")
#Initials:      _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Initials")
#Wrap:          _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Wrap")
#WrapWith:      _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.WrapWith")
#Indent:        _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Indent")
#Nindent:       _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Nindent")
#Snakecase:     _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Snakecase")
#Camelcase:     _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Camelcase")
#Kebabcase:     _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Kebabcase")
#Swapcase:      _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Swapcase")
#Plural:        _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Plural")
#SemverCompare: _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.SemverCompare")
#Semver:        _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260306200449-5ada224ec191/sprig.Semver")

// Untitle
t2: #Untitle("Hello World")

// Substr
t3: #Substr(0, 5, "hello world")
t4: #Substr(6, -1, "hello world")

// Nospace
t5: #Nospace("hello world")

// Trunc
t6: #Trunc(5, "hello world")
t7: #Trunc(-5, "hello world")

// Abbrev
t8:  #Abbrev(5, "hello world")
t9:  #Abbrev(3, "hello world")
t10: #Abbrev(20, "hello world")

// Abbrevboth
t11: #Abbrevboth(5, 12, "1234 5678 abcdefg")

// Initials
t12: #Initials("Hello World")

// Wrap
t13: #Wrap(5, "this is a long string")

// WrapWith
t14: #WrapWith(5, "\t", "this is a long string")

// Indent
t15: #Indent(4, "hello\nworld")

// Nindent
t16: #Nindent(4, "hello\nworld")

// Snakecase
t17: #Snakecase("HelloWorld")

// Camelcase
t18: #Camelcase("hello_world")

// Kebabcase
t19: #Kebabcase("HelloWorld")

// Swapcase
t20: #Swapcase("Hello World")

// Plural
t21: #Plural("item", "items", 1)
t22: #Plural("item", "items", 2)
t23: #Plural("item", "items", 0)

// SemverCompare
t24: #SemverCompare("^1.2.0", "1.2.3")
t25: #SemverCompare("^1.2.0", "2.0.0")

// Semver
t26: #Semver("1.2.3")
t27: #Semver("1.2.3-beta.1+c0ff33")
-- expected.json --
{
    "t10": "hello world",
    "t11": "...5678 a...",
    "t12": "HW",
    "t13": "this\nis a\nlong\nstring",
    "t14": "this\tis a\tlong\tstrin\tg",
    "t15": "    hello\n    world",
    "t16": "\n    hello\n    world",
    "t17": "hello_world",
    "t18": "HelloWorld",
    "t19": "hello-world",
    "t2": "hello world",
    "t20": "hELLO wORLD",
    "t21": "item",
    "t22": "items",
    "t23": "items",
    "t24": true,
    "t25": false,
    "t26": {
        "major": 1,
        "minor": 2,
        "original": "1.2.3",
        "patch": 3
    },
    "t27": {
        "major": 1,
        "metadata": "c0ff33",
        "minor": 2,
        "original": "1.2.3-beta.1+c0ff33",
        "patch": 3,
        "prerelease": "beta.1"
    },
    "t3": "hello",
    "t4": "world",
    "t5": "helloworld",
    "t6": "hello",
    "t7": "world",
    "t8": "he...",
    "t9": "hello world"
}
