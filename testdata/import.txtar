env HOME=$WORK/.home

# Tidy the CUE module to resolve dependencies.
exec cue mod tidy

# First run: all caches cold.
exec cue_user_funcs export --debug .
cmp stdout expected.json
stderr 'binary cache miss'
stderr 'shim cache miss'
stderr 'binary cached'

# Second run: binary cache should hit.
exec cue_user_funcs export --debug .
cmp stdout expected.json
stderr 'binary cache hit'

# Shim request: shim was cached during first run.
exec cue_user_funcs export --debug --shim .
cmp stdout expected_shim.go
stderr 'shim cache hit'

-- cue.mod/module.cue --
module: "test.example"
language: {
	version: "v0.16.0"
}
deps: {
	"github.com/cue-exp/cue_user_funcs@v0": {
		v: "v0.0.2"
	}
}
-- example.cue --
package example

import (
	"github.com/cue-exp/cue_user_funcs/semver"
	"github.com/cue-exp/cue_user_funcs/sprig"
)

// semver functions
version:   "v1.2.3-beta+build456"
isValid:   semver.#IsValid(version)
canonical: semver.#Canonical(version)
major:     semver.#Major(version)
compare:   semver.#Compare("v1.0.0", "v2.0.0")

// sprig functions
snakecase: sprig.#Snakecase("HelloWorld")
kebabcase: sprig.#Kebabcase("HelloWorld")
trunc:     sprig.#Trunc(5, "hello world")
plural:    sprig.#Plural("item", "items", 3)
-- expected_shim.go --
