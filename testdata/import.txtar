env HOME=$WORK/.home

# Tidy the CUE module to resolve dependencies.
exec cue mod tidy

# inject.sum should not exist yet.
! exists cue.mod/inject.sum

# First run: all caches cold. Should create inject.sum.
exec cue_user_funcs export --debug .
cmp stdout expected.json
stderr 'binary cache miss'
stderr 'shim cache miss'
stderr 'binary cached'
cmp cue.mod/inject.sum expected_inject.sum

# Second run: binary cache should hit.
exec cue_user_funcs export --debug .
cmp stdout expected.json
stderr 'binary cache hit'

# Shim request: shim was cached during first run.
exec cue_user_funcs export --debug --shim .
cmp stdout expected_shim.go
stderr 'shim cache hit'

# Corrupt inject.sum with a fresh cache: a bad hash should cause
# go mod tidy to fail with a checksum mismatch.
cp inject_bad.sum cue.mod/inject.sum
env HOME=$WORK/.home2
! exec cue_user_funcs export .
stderr 'SECURITY ERROR'

-- cue.mod/module.cue --
module: "test.example"
language: {
	version: "v0.16.0"
}
deps: {
	"github.com/cue-exp/cue_user_funcs@v0": {
		v: "v0.0.3"
	}
}
-- example.cue --
package example

import (
	"github.com/cue-exp/cue_user_funcs/semver"
	"github.com/cue-exp/cue_user_funcs/sprig"
	"github.com/cue-exp/cue_user_funcs/net/url"
)

// semver functions
version:   "v1.2.3-beta+build456"
isValid:   semver.#IsValid(version)
canonical: semver.#Canonical(version)
major:     semver.#Major(version)
compare:   semver.#Compare("v1.0.0", "v2.0.0")

// sprig functions
snakecase: sprig.#Snakecase("HelloWorld")
kebabcase: sprig.#Kebabcase("HelloWorld")
trunc:     sprig.#Trunc(5, "hello world")
plural:    sprig.#Plural("item", "items", 3)

// url functions
parsed: url.#Parse("https://example.com/path?q=1#frag")
-- expected.json --
{
    "canonical": "v1.2.3-beta",
    "compare": -1,
    "isValid": true,
    "kebabcase": "hello-world",
    "major": "v1",
    "parsed": {
        "ForceQuery": false,
        "Fragment": "frag",
        "Host": "example.com",
        "OmitHost": false,
        "Opaque": "",
        "Path": "/path",
        "RawFragment": "",
        "RawPath": "",
        "RawQuery": "q=1",
        "Scheme": "https"
    },
    "plural": "items",
    "snakecase": "hello_world",
    "trunc": "hello",
    "version": "v1.2.3-beta+build456"
}
-- expected_shim.go --
